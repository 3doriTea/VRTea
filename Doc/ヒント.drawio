  <diagram id="Pr85QwWsB-o2hgPguBkz" name="HTTPって？">
    <mxGraphModel dx="992" dy="535" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="RBv0RpqDThrJZLuFquK4-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="TCPで通信する&lt;div&gt;頭からただの文字列を送受信していくだけの通信方式&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="320" x="120" y="90" as="geometry" />
        </mxCell>
        <mxCell id="RBv0RpqDThrJZLuFquK4-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontColor=#333333;fontFamily=Cascadia Code;" value="クライアント(ブラウザ&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;) から サーバー へ&lt;/span&gt;&lt;div&gt;メインページにアクセスしたい！って時に送る文字列&lt;/div&gt;&lt;div&gt;※ \n は改行コードのこと&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;GET / HTTP/1.1 \n&lt;/div&gt;&lt;div&gt;Host: サイト名.ドメイン\n&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="320" x="580" y="140" as="geometry" />
        </mxCell>
        <mxCell id="RBv0RpqDThrJZLuFquK4-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontColor=#333333;fontFamily=Cascadia Code;" value="&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;サーバー から&amp;nbsp;&lt;/span&gt;クライアント(ブラウザ&lt;span style=&quot;color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193)); background-color: transparent;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;へ&lt;/span&gt;&lt;div&gt;メインページ(/index.html)へのアクセスが来た！って時に返す文字列&lt;/div&gt;&lt;div&gt;※ \n は改行コードのこと&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;HTTP/1.1 200 OK \n&lt;/div&gt;&lt;div&gt;Content-Type: text/html; charset=UTF-8\n&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Content-Length:&amp;nbsp;&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;!DOCTYPE html&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;lt;html lang=&quot;ja&quot;&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;lt;head&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;meta charset=&quot;UTF-8&quot;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;title&amp;gt;VRTea Server&amp;lt;/title&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;/head&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;lt;body&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;p&amp;gt;Hello World!&amp;lt;/p&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;lt;/body&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;/html&amp;gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
