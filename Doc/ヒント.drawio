  <diagram id="Pr85QwWsB-o2hgPguBkz" name="HTTPって？">
    <mxGraphModel dx="1097" dy="592" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="RBv0RpqDThrJZLuFquK4-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="TCPで通信する&lt;div&gt;頭からただの文字列を送受信していくだけの通信方式&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="320" x="120" y="90" as="geometry" />
        </mxCell>
        <mxCell id="RBv0RpqDThrJZLuFquK4-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontColor=#333333;fontFamily=Cascadia Code;" value="クライアント(ブラウザ&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;) から サーバー へ&lt;/span&gt;&lt;div&gt;メインページ(index.html)にアクセスしたい！って時に送る文字列&lt;/div&gt;&lt;div&gt;※ \n は改行コードのこと&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;GET /index.html HTTP/1.1 \n&lt;/div&gt;&lt;div&gt;Host: サイト名.ドメイン\n&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="320" x="560" y="40" as="geometry" />
        </mxCell>
        <mxCell id="RBv0RpqDThrJZLuFquK4-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontColor=#333333;fontFamily=Cascadia Code;" value="&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;サーバー から&amp;nbsp;&lt;/span&gt;クライアント(ブラウザ&lt;span style=&quot;color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193)); background-color: transparent;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;へ&lt;/span&gt;&lt;div&gt;メインページ(/index.html)へのアクセスが来た！って時に返す文字列&lt;/div&gt;&lt;div&gt;※ \n は改行コードのこと&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;HTTP/1.1 200 OK \n&lt;/div&gt;&lt;div&gt;Content-Type: text/html; charset=UTF-8\n&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Content-Length: 216&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;!DOCTYPE html&amp;gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;html lang=&quot;ja&quot;&amp;gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;head&amp;gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;meta charset=&quot;UTF-8&quot;&amp;gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&amp;gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;title&amp;gt;VRTea Server&amp;lt;/title&amp;gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;/head&amp;gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;body&amp;gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;p&amp;gt;Hello World!&amp;lt;/p&amp;gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;lt;/body&amp;gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;/html&amp;gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="300" width="570" x="560" y="200" as="geometry" />
        </mxCell>
        <mxCell id="RBv0RpqDThrJZLuFquK4-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="こう見ると、HTTPは本当に文字列を送っているだけとわかるはず！！&lt;div&gt;ブラウザはこれを受け取って文字列をUIとして描画しているだけ&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="420" x="80" y="170" as="geometry" />
        </mxCell>
        <mxCell id="RBv0RpqDThrJZLuFquK4-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="つまり、誰でも簡単にHTTP通信してサイトを表示できるってこと！" vertex="1">
          <mxGeometry height="60" width="420" x="80" y="240" as="geometry" />
        </mxCell>
        <mxCell id="4sZ1EPL9QspwKXpfkKnE-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontColor=#333333;fontFamily=Cascadia Code;" value="レスポンスの構造&lt;br&gt;&lt;div&gt;※ \n は改行コードのこと&lt;/div&gt;&lt;div&gt;※ {} は説明部分&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;HTTP/1.1 {ステータスコード} {ステータス}\n&lt;/div&gt;&lt;div&gt;(Content-Type: {コンテンツの形式})&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;(Content-Length: {コンテンツのバイト数})&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;({コンテンツ})&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="280" x="840" y="520" as="geometry" />
        </mxCell>
        <UserObject label="レスポンスステータスについて、詳しくはこちらから" link="https://developer.mozilla.org/ja/docs/Web/HTTP/Reference/Status" id="4sZ1EPL9QspwKXpfkKnE-3">
          <mxCell parent="1" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;align=center;verticalAlign=middle;fontColor=#0000EE;fontStyle=4;" vertex="1">
            <mxGeometry height="20" width="320" x="110" y="430" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="4sZ1EPL9QspwKXpfkKnE-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontColor=#333333;fontFamily=Cascadia Code;" value="リクエストの構造&lt;br&gt;&lt;div&gt;※ \n は改行コードのこと&lt;/div&gt;&lt;div&gt;※ {} は説明部分&lt;/div&gt;&lt;div&gt;※ () は書かなくてもいいやつ&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;{メソッド名} {アクセスするパス} HTTP/1.1\n&lt;/div&gt;&lt;div&gt;Host: {サイトのドメイン}&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;(Content-Type: {コンテンツの形式})&lt;/div&gt;&lt;div&gt;(Content-Length: {コンテンツのバイト数})&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;\n&lt;/span&gt;&lt;/div&gt;&lt;div&gt;\n&lt;/div&gt;&lt;div&gt;({コンテンツ})&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="280" x="560" y="520" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="M20bRaeX9DU7_XQVFYFj" name="Jsonって？">
    <mxGraphModel dx="1042" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="JiQiqSgaOlXti8mwgZLc-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="要するに、メンバ変数だけの構造体を文字列で表現する方式のこと" vertex="1">
          <mxGeometry height="190" width="400" x="80" y="40" as="geometry" />
        </mxCell>
        <mxCell id="JiQiqSgaOlXti8mwgZLc-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontFamily=Cascadia Code;" value="{&lt;div&gt;&amp;nbsp; &quot;head&quot;: &quot;update&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;pos&quot;: {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;x&quot;: 30,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;y&quot;: 24.0,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;z&quot;: -39.23&lt;/div&gt;&lt;div&gt;&amp;nbsp; },&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;isDead&quot;: false&lt;/div&gt;&lt;div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="210" x="650" y="175" as="geometry" />
        </mxCell>
        <mxCell id="JiQiqSgaOlXti8mwgZLc-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontFamily=Cascadia Code;" value="&lt;div&gt;struct Position&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; int x;&lt;/div&gt;&lt;div&gt;&amp;nbsp; float y;&lt;/div&gt;&lt;div&gt;&amp;nbsp; float z;&lt;/div&gt;&lt;div&gt;};&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;struct Message&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; std::string head = &quot;update&quot;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; Position&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;pos = { 30, 24.0f, -39.23f };&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; bool isDead = false;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;};&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="320" x="210" y="120" as="geometry" />
        </mxCell>
        <mxCell id="JiQiqSgaOlXti8mwgZLc-5" edge="1" parent="1" source="JiQiqSgaOlXti8mwgZLc-3" style="shape=flexArrow;endArrow=classic;startArrow=classic;html=1;rounded=0;" target="JiQiqSgaOlXti8mwgZLc-2" value="">
          <mxGeometry height="100" relative="1" width="100" as="geometry">
            <mxPoint x="480" y="450" as="sourcePoint" />
            <mxPoint x="580" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="JiQiqSgaOlXti8mwgZLc-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="構造体さえわかれば、Jsonに変換も、Jsonから変換も&lt;div&gt;どっちもできる！&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="380" x="400" y="325" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="TMebdkAmULCpiZoH2ZTW" name="WebAPIって？">
    <mxGraphModel dx="1042" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="vZicBRMXHch0rLbiWPhN-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="先に「&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;HTTPって？」と「Jsonって？」のページを見てください！&lt;/span&gt;" vertex="1">
          <mxGeometry height="40" width="400" x="120" y="80" as="geometry" />
        </mxCell>
        <mxCell id="I15pg9xXQb-Vvn4n3eV9-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="HTTPの例では、index.htmlという名前の、HTMLファイル(中身はテキスト)を返していた！&lt;div&gt;でもJsonっていう形式のテキストファイルで、C++でやった構造体を文字列として表現できた！&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;なら、アカウントの登録情報、サインイン情報とかも文字列として、&lt;/div&gt;&lt;div&gt;それをHTTPで送信できるのでは！？&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="540" x="240" y="160" as="geometry" />
        </mxCell>
        <mxCell id="s3MENxSNlRsTAhkW-0Ce-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="結論　できる" vertex="1">
          <mxGeometry height="90" width="540" x="230" y="250" as="geometry" />
        </mxCell>
        <mxCell id="s3MENxSNlRsTAhkW-0Ce-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="GETリクエストではなく、POSTリクエストとか使う&lt;div&gt;先頭に GET ではなく POST って書いて、&lt;/div&gt;&lt;div&gt;ContentType: application/json&lt;/div&gt;&lt;div&gt;って書いたらok&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="540" x="230" y="350" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
