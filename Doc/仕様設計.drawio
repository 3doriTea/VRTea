  <diagram id="zCbaAdNY7vpRBdqdOtn5" name="GitHubの使い方">
    <mxGraphModel dx="1489" dy="803" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hLupf26O39RY7G9uMwoR-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Cascadia Code;" value="&lt;h1&gt;GitHubの使い方&lt;/h1&gt;" vertex="1">
          <mxGeometry height="40" width="200" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="m7dreOPpXmCefqGXsiUq-16" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;コミットってなに&lt;/h1&gt;&lt;p&gt;RPGのセーブとロード機能みたいなやつ&lt;/p&gt;&lt;p&gt;ゲームのいい所でもセーブするし、ゲームを終わる前にもセーブする&lt;br&gt;そのとき、なんのセーブか分からなくならないように、メモを付ける&lt;br&gt;それがコミットメッセージ&lt;/p&gt;&lt;h1&gt;プッシュとプルってなに&lt;/h1&gt;&lt;div&gt;家のPCでセーブしたデータだけど、学校でもプレイしたい！&lt;br&gt;そんなときはクラウドセーブ！Githubがクラウドセーブしてくれる。&lt;/div&gt;&lt;p&gt;Githubにデータを送信したいときは「プッシュ」&lt;br&gt;Githubからデータを受信したいときは「プル」&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="280" width="530" x="40" y="120" as="geometry" />
        </mxCell>
        <mxCell id="m7dreOPpXmCefqGXsiUq-17" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="490" width="680" x="40" y="440" as="geometry" />
        </mxCell>
        <mxCell id="m7dreOPpXmCefqGXsiUq-1" parent="m7dreOPpXmCefqGXsiUq-17" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;ブランチってなに&lt;/h1&gt;&lt;p&gt;作業のデータを分岐させるやつ&lt;br&gt;RPGのセーブとロード機能みたいな&lt;/p&gt;&lt;p&gt;ボスにとどめを刺したエンドロール、刺さなかったエンドロール&lt;br&gt;どっちも進めたいときは、まずは選択前にコミット &amp;amp; プッシュ する。&lt;/p&gt;&lt;p&gt;そして、とどめを刺すブランチを作り、分岐させる&lt;br&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;あと、とどめを刺さないブランチを作り、分岐させる&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="490" width="679.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="m7dreOPpXmCefqGXsiUq-2" parent="m7dreOPpXmCefqGXsiUq-17" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" value="「main」&lt;div&gt;ブランチ&lt;/div&gt;" vertex="1">
          <mxGeometry height="75.33478278932571" width="75.33478278932571" x="339.0065225519657" y="170" as="geometry" />
        </mxCell>
        <mxCell id="m7dreOPpXmCefqGXsiUq-3" parent="m7dreOPpXmCefqGXsiUq-17" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" value="「server」&lt;div&gt;ブランチ&lt;/div&gt;" vertex="1">
          <mxGeometry height="75.33478278932571" width="75.33478278932571" x="414.3413053412914" y="250" as="geometry" />
